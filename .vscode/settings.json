{
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "_archived": true,
    "backtest-campaigns": true,
    "campaigns": true,
    "catalogs": true,
    "run-store": true,
    "data/cache": true,
    "data/raw": true,
    "research/campaigns/archive": true,
    "research/evidence": true,
    "research_artifacts/*.*": true
  },
  "search.exclude": {
    "_archived/**": true,
    "backtest-campaigns/**": true,
    "campaigns/**": true,
    "catalogs/**": true,
    "run-store/**": true,
    "data/cache/**": true,
    "data/raw/**": true,
    "research/campaigns/archive/**": true,
    "research/evidence/**": true,
    "research_artifacts/**": true
  },
  "files.watcherExclude": {
    "**/backtest-campaigns/**": true,
    "**/catalogs/**": true,
    "**/run-store/**": true,
    "**/data/cache/**": true,
    "**/data/raw/**": true,
    "**/research/campaigns/archive/**": true,
    "**/research/evidence/**": true
  },
  "yaml.schemas": {
    "./schemas/campaign.schema.json": [
      "research/campaigns/active/*/campaign.yaml",
      "research/campaigns/archive/*/campaign.yaml"
    ],
    "./schemas/variant-config.schema.json": [
      "research/campaigns/active/*/variants/*/config.yaml",
      "research/campaigns/archive/*/variants/*/config.yaml",
      "research/campaigns/archive/*/rescue_attempts/*/*/config.yaml"
    ],
    "./schemas/research-settings.schema.json": "config/research_settings.yaml",
    "./schemas/storage-layout.schema.json": "config/storage_layout.yaml"
  }
}
