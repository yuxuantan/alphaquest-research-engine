{
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "_archived": true,
    "backtest-campaigns": true,
    "data/cache": true,
    "data/raw": true,
    "research_artifacts/*.*": true,
    "campaigns/*/rescue_attempts": true
  },
  "search.exclude": {
    "_archived/**": true,
    "backtest-campaigns/**": true,
    "data/cache/**": true,
    "data/raw/**": true,
    "research_artifacts/**": true,
    "views/**": true
  },
  "files.watcherExclude": {
    "**/backtest-campaigns/**": true,
    "**/data/cache/**": true,
    "**/data/raw/**": true
  }
}
