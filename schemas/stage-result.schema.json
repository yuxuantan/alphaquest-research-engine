{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphaquest.local/schemas/stage-result.schema.json",
  "title": "AlphaQuest Stage Result",
  "type": "object",
  "required": ["stage", "label", "status", "passed", "criteria"],
  "properties": {
    "stage": {"type": "string"},
    "label": {"type": "string"},
    "status": {"enum": ["passed", "failed", "skipped", "error"]},
    "passed": {"type": "boolean"},
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric", "passed"],
        "properties": {
          "metric": {"type": "string"},
          "passed": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
