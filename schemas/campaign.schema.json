{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphaquest.local/schemas/campaign.schema.json",
  "title": "AlphaQuest Campaign",
  "type": "object",
  "required": ["campaign_id"],
  "properties": {
    "campaign_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_]*$"},
    "title": {"type": "string", "minLength": 1},
    "decision": {"enum": ["PASS", "FAIL", "NEEDS MANUAL REVIEW", null]},
    "status": {"type": ["string", "object", "null"]},
    "instrument": {"type": "string"},
    "symbol": {"type": "string"},
    "timeframe": {"type": "string"},
    "edge_family": {"type": "string"},
    "hypothesis": {"type": "string"},
    "sources": {"type": "array", "items": {"type": "object"}},
    "variants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {"oneOf": [{"type": "string"}, {"type": "object"}]}
    },
    "rescue_policy": {"type": "object"}
  },
  "additionalProperties": true
}
