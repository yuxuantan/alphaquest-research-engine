{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphaquest.local/schemas/storage-layout.schema.json",
  "title": "AlphaQuest storage layout",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "active_campaign_root",
    "archive_campaign_roots",
    "evidence_roots",
    "research_artifact_root",
    "catalog_root",
    "views_root",
    "run_store_root",
    "migration_manifest",
    "legacy_prefixes"
  ],
  "properties": {
    "schema": { "const": "alphaquest.storage-layout/v1" },
    "active_campaign_root": { "$ref": "#/$defs/path" },
    "archive_campaign_roots": { "$ref": "#/$defs/paths" },
    "evidence_roots": { "$ref": "#/$defs/paths" },
    "research_artifact_root": { "$ref": "#/$defs/path" },
    "catalog_root": { "$ref": "#/$defs/path" },
    "views_root": { "$ref": "#/$defs/path" },
    "run_store_root": { "$ref": "#/$defs/path" },
    "migration_manifest": { "$ref": "#/$defs/path" },
    "legacy_prefixes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/path" }
    }
  },
  "$defs": {
    "path": { "type": "string", "minLength": 1 },
    "paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/path" }
    }
  }
}
